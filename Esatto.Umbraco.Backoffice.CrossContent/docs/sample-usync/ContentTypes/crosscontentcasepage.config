<?xml version="1.0" encoding="utf-8"?>
<!-- SAMPLE — REGENERATE all Key GUIDs. The Definition GUID must equal your CrossContentCasePicker
     DataType Key; the AllowedTemplates/DefaultTemplate must match your template's Key/Alias; the
     metaData composition Key must be your site's own. Add this type to your caseListingPage <Structure>. -->
<ContentType Key="00000000-0000-0000-0000-000000000002" Alias="crossContentCasePage" Level="2">
  <Info>
    <Name>Cross Content Case Page</Name>
    <Icon>icon-handshake color-black</Icon>
    <Thumbnail>folder.png</Thumbnail>
    <Description>A case from another site (pulled live) that appears as a card in the case listing and links out.</Description>
    <AllowAtRoot>False</AllowAtRoot>
    <ListView>00000000-0000-0000-0000-000000000000</ListView>
    <Variations>Culture</Variations>
    <IsElement>false</IsElement>
    <Folder>Pages</Folder>
    <Compositions>
      <Composition Key="00000000-0000-0000-0000-0000000000aa">metaData</Composition>
    </Compositions>
    <DefaultTemplate>CrossContentCasePage</DefaultTemplate>
    <AllowedTemplates>
      <Template Key="00000000-0000-0000-0000-000000000003">CrossContentCasePage</Template>
    </AllowedTemplates>
  </Info>
  <Structure />
  <GenericProperties>
    <GenericProperty>
      <Key>00000000-0000-0000-0000-000000000004</Key>
      <Name>Cross Content Case</Name>
      <Alias>crossContentCase</Alias>
      <Definition>00000000-0000-0000-0000-000000000001</Definition>
      <Type>Umbraco.Plain.Json</Type>
      <Mandatory>true</Mandatory>
      <SortOrder>0</SortOrder>
      <Tab Alias="content">Content</Tab>
      <Variations>Culture</Variations>
    </GenericProperty>
  </GenericProperties>
  <Tabs>
    <Tab>
      <Key>00000000-0000-0000-0000-000000000005</Key>
      <Caption>Content</Caption>
      <Alias>content</Alias>
      <Type>Tab</Type>
      <SortOrder>0</SortOrder>
    </Tab>
  </Tabs>
</ContentType>