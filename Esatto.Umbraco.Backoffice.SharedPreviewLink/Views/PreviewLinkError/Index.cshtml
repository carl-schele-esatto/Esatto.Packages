@using Esatto.Umbraco.Backoffice.SharedPreviewLink
@{
    var variant = Context.Items[PreviewLinkMiddleware.ErrorItemsKey] as string ?? "invalid";

    var (heading, body) = variant switch
    {
        "expired" => (
            "This preview link has expired",
            "Ask the sender to generate a new link."),
        "notfound" => (
            "This page is no longer available",
            "The page may have been removed since the link was sent."),
        _ => (
            "This preview link is invalid",
            "Double-check the link in your email, or ask the sender to generate a new one."),
    };

    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@heading</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
        :root {
            --bp-bg: #ffffff;
            --bp-fg: #111111;
            --bp-fg-muted: rgba(17, 17, 17, 0.65);
        }
        @@media (prefers-color-scheme: dark) {
            :root {
                --bp-bg: #111111;
                --bp-fg: #f5f5f5;
                --bp-fg-muted: rgba(245, 245, 245, 0.65);
            }
        }
        html, body { margin: 0; padding: 0; background-color: var(--bp-bg); color: var(--bp-fg); }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            min-height: 100dvh;
        }
        .preview-link-error {
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }
        .preview-link-error__inner {
            max-width: 480px;
            text-align: center;
        }
        .preview-link-error__heading {
            font-size: clamp(2rem, 4vw, 3rem);
            line-height: 1.2;
            margin: 0 0 0.75rem 0;
        }
        .preview-link-error__body {
            font-size: 1.125rem;
            line-height: 1.5;
            margin: 0;
            color: var(--bp-fg-muted);
        }
    </style>
</head>
<body>
    <main class="preview-link-error">
        <div class="preview-link-error__inner">
            <h1 class="preview-link-error__heading">@heading</h1>
            <p class="preview-link-error__body">@body</p>
        </div>
    </main>
</body>
</html>
