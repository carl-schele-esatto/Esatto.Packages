{
  "$schema": "../umbraco-package-schema.json",
  "id": "backoffice-preview-link",
  "name": "Backoffice Preview Link",
  "version": "0.1.0",
  "extensions": [
    {
      "name": "Backoffice Share Preview Workspace Action",
      "alias": "Backoffice.PreviewLink.SharePreviewWorkspaceAction",
      "type": "workspaceAction",
      "kind": "default",
      "weight": 200,
      "api": "/App_Plugins/Backoffice.PreviewLink/share-preview-action.js",
      "element": "/App_Plugins/Backoffice.PreviewLink/share-preview-button.js",
      "elementName": "backoffice-preview-link-button",
      "meta": {
        "label": "Share preview"
      },
      "conditions": [
        { "alias": "Umb.Condition.WorkspaceAlias", "match": "Umb.Workspace.Document" }
      ]
    }
  ]
}
